# ─────────────────────────────────────────────────────────────────────────────
# FORGE — Environment Variables
# Copy to .env for development, .env.prod for production
# NEVER commit .env or .env.prod to git
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment ───────────────────────────────────────────────────────────────
FORGE_ENV=development                    # development | staging | production
FORGE_SECRET_KEY=change-me-32-chars-min

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=forge
POSTGRES_PASSWORD=forge_dev_password
POSTGRES_DB=forge
POSTGRES_HOST=postgres                   # service name in docker compose
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://forge:forge_dev_password@postgres:5432/forge

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                          # empty for dev, set for prod
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_DEFAULT=claude-opus-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001   # for lightweight tasks
ANTHROPIC_MAX_TOKENS_DEFAULT=8096
ANTHROPIC_MAX_RETRIES=3

# Token and cost limits
FORGE_MAX_TOKENS_PER_RUN=500000
FORGE_MAX_DAILY_SPEND_USD=100
FORGE_COST_ALERT_PERCENT=80

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...                 # for socket mode
SLACK_SIGNING_SECRET=...
SLACK_SOCKET_MODE=true

# ── Discord (Phase 2) ─────────────────────────────────────────────────────────
# DISCORD_BOT_TOKEN=...
# DISCORD_GUILD_ID=...

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_APP_ID=...
GITHUB_APP_PRIVATE_KEY_PATH=/app/secrets/github-app.pem
GITHUB_WEBHOOK_SECRET=...
# OR use personal access token for MVP:
GITHUB_TOKEN=ghp_...

# ── AWS S3 (artifact storage) ─────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-west-2
FORGE_S3_BUCKET=forge-artifacts-teamworks

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG                          # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                          # json | pretty (pretty for dev)
OTEL_EXPORTER_OTLP_ENDPOINT=           # leave empty to disable tracing in dev
OTEL_SERVICE_NAME=forge

# ── Skill Feeds ───────────────────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=...                 # for web search skill
# NOTION_API_KEY=...                     # for internal wiki ingestion

# ── Feature Flags ─────────────────────────────────────────────────────────────
FORGE_ENABLE_PGVECTOR=true              # false = SQL-only search (MVP fallback)
FORGE_ENABLE_DISCORD=false
FORGE_ENABLE_SKILL_DRILLS=false        # enable in Phase 2
FORGE_ENABLE_DAILY_DIGEST=false        # enable in Phase 2
FORGE_ENABLE_DEPLOY_VERIFY=false       # enable when Vercel webhook configured

# ── Git ops ───────────────────────────────────────────────────────────────────
GIT_WORKSPACE=/tmp/forge-repos          # where repos are cloned
GIT_AUTHOR_NAME=FORGE
GIT_AUTHOR_EMAIL=forge-bot@acme.com

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1                           # 1 for dev, 4+ for prod
